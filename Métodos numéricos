        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# =========================================================\n",
        "# Problema:\n",
        "# y' - y = sin(pi*x),   y(0) = 1\n",
        "# Reescrevendo:\n",
        "# y' = y + sin(pi*x)\n",
        "# =========================================================\n",
        "\n",
        "def f(x, y):\n",
        "    return y + np.sin(np.pi * x)\n",
        "\n",
        "# Solução exata\n",
        "def y_exata(x):\n",
        "    return (\n",
        "        (-np.sin(np.pi * x) - np.pi * np.cos(np.pi * x)) / (1 + np.pi**2)\n",
        "        + (1 + np.pi / (1 + np.pi**2)) * np.exp(x)\n",
        "    )\n",
        "\n",
        "# =========================================================\n",
        "# Parâmetros\n",
        "# =========================================================\n",
        "h = 0.1\n",
        "x0 = 0.0\n",
        "xf = 1.0\n",
        "\n",
        "x = np.arange(x0, xf + h, h)\n",
        "N = len(x)\n",
        "\n",
        "# =========================================================\n",
        "# Forward Euler\n",
        "# y_{n+1} = y_n + h*(y_n + sin(pi*x_n))\n",
        "# =========================================================\n",
        "y_forward = np.zeros(N)\n",
        "y_forward[0] = 1.0\n",
        "\n",
        "for n in range(N - 1):\n",
        "    y_forward[n + 1] = y_forward[n] + h * (y_forward[n] + np.sin(np.pi * x[n]))\n",
        "\n",
        "# =========================================================\n",
        "# Backward Euler\n",
        "# (y_{n+1} - y_n)/h = y_{n+1} + sin(pi*x_{n+1})\n",
        "# y_{n+1} = (y_n + h*sin(pi*x_{n+1})) / (1 - h)\n",
        "# =========================================================\n",
        "y_backward = np.zeros(N)\n",
        "y_backward[0] = 1.0\n",
        "\n",
        "for n in range(N - 1):\n",
        "    y_backward[n + 1] = (\n",
        "        y_backward[n] + h * np.sin(np.pi * x[n + 1])\n",
        "    ) / (1 - h)\n",
        "\n",
        "# =========================================================\n",
        "# Central Difference\n",
        "# (y_{n+1} - y_{n-1})/(2h) = y_n + sin(pi*x_n)\n",
        "# y_{n+1} = y_{n-1} + 2h*(y_n + sin(pi*x_n))\n",
        "#\n",
        "# Precisa de y1 inicial, então usamos Forward Euler para iniciar.\n",
        "# =========================================================\n",
        "y_central = np.zeros(N)\n",
        "y_central[0] = 1.0\n",
        "\n",
        "# arranque com Forward Euler\n",
        "y_central[1] = y_central[0] + h * (y_central[0] + np.sin(np.pi * x[0]))\n",
        "\n",
        "for n in range(1, N - 1):\n",
        "    y_central[n + 1] = y_central[n - 1] + 2 * h * (\n",
        "        y_central[n] + np.sin(np.pi * x[n])\n",
        "    )\n",
        "\n",
        "# =========================================================\n",
        "# Crank-Nicolson\n",
        "#\n",
        "# (y_{n+1} - y_n)/h = 1/2 * [f(x_n,y_n) + f(x_{n+1},y_{n+1})]\n",
        "#\n",
        "# Como f(x,y) = y + sin(pi*x), então:\n",
        "#\n",
        "# (y_{n+1} - y_n)/h =\n",
        "# 1/2 * [(y_n + sin(pi*x_n)) + (y_{n+1} + sin(pi*x_{n+1}))]\n",
        "#\n",
        "# Isolando y_{n+1}:\n",
        "#\n",
        "# y_{n+1} =\n",
        "# [ (1 + h/2)*y_n + (h/2)*(sin(pi*x_n) + sin(pi*x_{n+1})) ] / (1 - h/2)\n",
        "# =========================================================\n",
        "y_cn = np.zeros(N)\n",
        "y_cn[0] = 1.0\n",
        "\n",
        "for n in range(N - 1):\n",
        "    numerador = (\n",
        "        (1 + h / 2) * y_cn[n]\n",
        "        + (h / 2) * (np.sin(np.pi * x[n]) + np.sin(np.pi * x[n + 1]))\n",
        "    )\n",
        "    denominador = 1 - h / 2\n",
        "    y_cn[n + 1] = numerador / denominador\n",
        "\n",
        "# =========================================================\n",
        "# Solução exata\n",
        "# =========================================================\n",
        "y_true = y_exata(x)\n",
        "\n",
        "# =========================================================\n",
        "# Erros absolutos\n",
        "# =========================================================\n",
        "erro_forward = np.abs(y_true - y_forward)\n",
        "erro_backward = np.abs(y_true - y_backward)\n",
        "erro_central = np.abs(y_true - y_central)\n",
        "erro_cn = np.abs(y_true - y_cn)\n",
        "\n",
        "# =========================================================\n",
        "# Tabela de resultados\n",
        "# =========================================================\n",
        "print(\"--------------------------------------------------------------------------\")\n",
        "print(\" x       Exata       Forward     Backward    Central     Crank-Nicolson\")\n",
        "print(\"--------------------------------------------------------------------------\")\n",
        "for i in range(N):\n",
        "    print(f\"{x[i]:.1f}   \"\n",
        "          f\"{y_true[i]:.6f}   \"\n",
        "          f\"{y_forward[i]:.6f}   \"\n",
        "          f\"{y_backward[i]:.6f}   \"\n",
        "          f\"{y_central[i]:.6f}   \"\n",
        "          f\"{y_cn[i]:.6f}\")\n",
        "\n",
        "print(\"\\n-------------------- ERRO MÁXIMO --------------------\")\n",
        "print(f\"Forward Euler   : {np.max(erro_forward):.8f}\")\n",
        "print(f\"Backward Euler  : {np.max(erro_backward):.8f}\")\n",
        "print(f\"Central         : {np.max(erro_central):.8f}\")\n",
        "print(f\"Crank-Nicolson  : {np.max(erro_cn):.8f}\")\n",
        "\n",
        "# =========================================================\n",
        "# Gráfico da solução\n",
        "# =========================================================\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(x, y_true, 'k-', linewidth=2, label='Solução exata')\n",
        "plt.plot(x, y_forward, 'o--', label='Forward Euler')\n",
        "plt.plot(x, y_backward, 's--', label='Backward Euler')\n",
        "plt.plot(x, y_central, 'd--', label='Central')\n",
        "plt.plot(x, y_cn, 'x--', label='Crank-Nicolson')\n",
        "\n",
        "plt.xlabel('x')\n",
        "plt.ylabel('y(x)')\n",
        "plt.title(\"Comparação dos métodos numéricos\")\n",
        "plt.grid(True)\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n",
        "# =========================================================\n",
        "# Gráfico dos erros\n",
        "# =========================================================\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(x, erro_forward, 'o--', label='Erro Forward')\n",
        "plt.plot(x, erro_backward, 's--', label='Erro Backward')\n",
        "plt.plot(x, erro_central, 'd--', label='Erro Central')\n",
        "plt.plot(x, erro_cn, 'x--', label='Erro Crank-Nicolson')\n",
        "\n",
        "plt.xlabel('x')\n",
        "plt.ylabel('Erro absoluto')\n",
        "plt.title(\"Erro absoluto dos métodos\")\n",
        "plt.grid(True)\n",
        "plt.legend()\n",
        "plt.show()"
      ]
